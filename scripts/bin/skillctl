#!/bin/bash
set -euo pipefail

SKILLCTL_DIR="${HOME}/.config/skillctl"
REPOS_DIR="${SKILLCTL_DIR}/repos"

# Harness name -> skill directory pattern (relative, <name> is placeholder)
declare -A HARNESSES=(
  ["Claude Code"]=".claude/skills/<name>"
  ["OpenAI Codex"]=".agents/skills/<name>"
  ["OpenCode"]=".agents/skills/<name>"
  ["KiloCode"]=".kilocode/skills/<name>"
  ["Gemini CLI"]=".agents/skills/<name>"
  ["pi"]=".pi/skills/<name>"
  ["amp"]=".agents/skills/<name>"
  ["Cursor"]=".cursor/skills/<name>"
  ["cline"]=".cline/skills/<name>"
  ["goose"]=".goose/skills/<name>"
  ["Warp"]=".agents/skills/<name>"
  ["GitHub Copilot"]=".github/skills/<name>"
  ["Qwen"]=".qwen/skills/<name>"
)

die() { echo "error: $*" >&2; exit 1; }

require_gum() {
  command -v gum &>/dev/null || die "gum is required but not installed. Install it: https://github.com/charmbracelet/gum"
}

ensure_dirs() {
  mkdir -p "$REPOS_DIR"
}

# Extract repo name from a URL or path
repo_name_from() {
  local source="$1"
  basename "${source%.git}"
}

# List all skill names inside a repo
list_skills_in_repo() {
  local repo_dir="$1"
  if [[ -d "${repo_dir}/skills" ]]; then
    find "${repo_dir}/skills" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
  fi
}

# Resolve harness skill dir for a given skill name and base path
harness_skill_dir() {
  local harness="$1" skill_name="$2" base="$3"
  local pattern="${HARNESSES[$harness]}"
  local rel="${pattern/<name>/$skill_name}"
  echo "${base}/${rel}"
}

# Find all existing symlinks pointing to a skill across all harnesses
find_links_for_skill() {
  local skill_name="$1" base="$2"
  local seen=()
  for harness in "${!HARNESSES[@]}"; do
    local target
    target="$(harness_skill_dir "$harness" "$skill_name" "$base")"
    # deduplicate paths (multiple harnesses share .agents/)
    local already=false
    for s in "${seen[@]+"${seen[@]}"}"; do
      [[ "$s" == "$target" ]] && already=true && break
    done
    $already && continue
    seen+=("$target")
    if [[ -L "$target" ]]; then
      echo "$target"
    fi
  done
}

# Get unique harness dirs for selected harnesses
unique_harness_dirs() {
  local skill_name="$1" base="$2"
  shift 2
  local harness_names=("$@")
  local seen=()
  for harness in "${harness_names[@]}"; do
    local target
    target="$(harness_skill_dir "$harness" "$skill_name" "$base")"
    local already=false
    for s in "${seen[@]+"${seen[@]}"}"; do
      [[ "$s" == "$target" ]] && already=true && break
    done
    $already && continue
    seen+=("$target")
    echo "$target"
  done
}

# ── install ──────────────────────────────────────────────────────────────────

cmd_install() {
  [[ $# -lt 1 ]] && die "usage: skillctl install <url|local-path>"
  ensure_dirs

  local source="$1"
  local name
  name="$(repo_name_from "$source")"

  if [[ -d "${REPOS_DIR}/${name}" ]]; then
    die "repo '${name}' is already installed"
  fi

  if [[ -d "$source" ]]; then
    # Local directory — validate it has a skills/ folder
    [[ -d "${source}/skills" ]] || die "local directory '${source}' has no skills/ folder"
    cp -r "$source" "${REPOS_DIR}/${name}"
    echo "copied '${source}' to ${REPOS_DIR}/${name}"
  else
    # Treat as URL — clone
    git clone "$source" "${REPOS_DIR}/${name}"
  fi

  local skills
  skills="$(list_skills_in_repo "${REPOS_DIR}/${name}")"
  if [[ -z "$skills" ]]; then
    echo "warning: no skills found in ${name}/skills/"
  else
    echo "installed skills:"
    echo "$skills" | sed 's/^/  /'
  fi
}

# ── interactive skill picker ─────────────────────────────────────────────────

pick_skills() {
  local all_skills=()
  for repo_dir in "${REPOS_DIR}"/*/; do
    [[ -d "$repo_dir" ]] || continue
    local repo_name
    repo_name="$(basename "$repo_dir")"
    while IFS= read -r skill; do
      [[ -n "$skill" ]] && all_skills+=("${repo_name}/${skill}")
    done < <(list_skills_in_repo "$repo_dir")
  done

  [[ ${#all_skills[@]} -eq 0 ]] && die "no skills installed"

  local selected
  selected="$(printf '%s\n' "${all_skills[@]}" | gum choose --no-limit --header "Select skills to link:")"
  [[ -z "$selected" ]] && die "no skills selected"
  echo "$selected"
}

pick_harnesses() {
  local harness_names
  harness_names="$(printf '%s\n' "${!HARNESSES[@]}" | sort)"

  local selected
  selected="$(echo "$harness_names" | gum choose --no-limit --header "Select harnesses:")"
  [[ -z "$selected" ]] && die "no harnesses selected"
  echo "$selected"
}

# ── link ─────────────────────────────────────────────────────────────────────

cmd_link() {
  require_gum

  local skill_arg="" is_global=false project_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global) is_global=true; shift ;;
      --project) project_dir="$2"; shift 2 ;;
      *) skill_arg="$1"; shift ;;
    esac
  done

  local base
  if $is_global; then
    base="$HOME"
  else
    base="${project_dir:-$(pwd)}"
  fi

  # Determine skills to link
  local skills_to_link=()
  if [[ -n "$skill_arg" ]]; then
    # Validate format repo/skill
    if [[ "$skill_arg" == */* ]]; then
      local repo_part="${skill_arg%%/*}"
      local skill_part="${skill_arg#*/}"
      [[ -d "${REPOS_DIR}/${repo_part}/skills/${skill_part}" ]] || die "skill '${skill_arg}' not found"
      skills_to_link+=("$skill_arg")
    else
      # Search all repos for this skill name
      local found=false
      for repo_dir in "${REPOS_DIR}"/*/; do
        local rn
        rn="$(basename "$repo_dir")"
        if [[ -d "${repo_dir}/skills/${skill_arg}" ]]; then
          skills_to_link+=("${rn}/${skill_arg}")
          found=true
        fi
      done
      $found || die "skill '${skill_arg}' not found in any repo"
    fi
  else
    while IFS= read -r line; do
      [[ -n "$line" ]] && skills_to_link+=("$line")
    done < <(pick_skills)
  fi

  # Pick harnesses
  local selected_harnesses=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && selected_harnesses+=("$line")
  done < <(pick_harnesses)

  # Create symlinks
  for entry in "${skills_to_link[@]}"; do
    local repo_part="${entry%%/*}"
    local skill_part="${entry#*/}"
    local skill_source="${REPOS_DIR}/${repo_part}/skills/${skill_part}"

    while IFS= read -r target_dir; do
      mkdir -p "$(dirname "$target_dir")"
      if [[ -L "$target_dir" ]]; then
        echo "already linked: ${target_dir}"
      elif [[ -e "$target_dir" ]]; then
        echo "skipped (non-symlink exists): ${target_dir}"
      else
        ln -s "$skill_source" "$target_dir"
        echo "linked: ${target_dir} -> ${skill_source}"
      fi
    done < <(unique_harness_dirs "$skill_part" "$base" "${selected_harnesses[@]}")
  done
}

# ── unlink ───────────────────────────────────────────────────────────────────

cmd_unlink() {
  require_gum

  local skill_arg="" is_global=false project_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global) is_global=true; shift ;;
      --project) project_dir="$2"; shift 2 ;;
      *) skill_arg="$1"; shift ;;
    esac
  done

  local base
  if $is_global; then
    base="$HOME"
  else
    base="${project_dir:-$(pwd)}"
  fi

  local skills_to_unlink=()
  if [[ -n "$skill_arg" ]]; then
    local skill_name="${skill_arg#*/}"
    [[ "$skill_arg" == */* ]] || skill_name="$skill_arg"
    skills_to_unlink+=("$skill_name")
  else
    # Interactive: show only currently linked skills
    local linked_skills=()
    for repo_dir in "${REPOS_DIR}"/*/; do
      [[ -d "$repo_dir" ]] || continue
      while IFS= read -r skill; do
        [[ -n "$skill" ]] || continue
        local links
        links="$(find_links_for_skill "$skill" "$base")"
        [[ -n "$links" ]] && linked_skills+=("$skill")
      done < <(list_skills_in_repo "$repo_dir")
    done

    [[ ${#linked_skills[@]} -eq 0 ]] && die "no linked skills found"

    local selected
    selected="$(printf '%s\n' "${linked_skills[@]}" | sort -u | gum choose --no-limit --header "Select skills to unlink:")"
    [[ -z "$selected" ]] && die "no skills selected"
    while IFS= read -r line; do
      [[ -n "$line" ]] && skills_to_unlink+=("$line")
    done <<< "$selected"
  fi

  for skill_name in "${skills_to_unlink[@]}"; do
    while IFS= read -r link; do
      rm "$link"
      echo "unlinked: ${link}"
    done < <(find_links_for_skill "$skill_name" "$base")
  done
}

# ── uninstall ────────────────────────────────────────────────────────────────

cmd_uninstall() {
  [[ $# -lt 1 ]] && die "usage: skillctl uninstall <repo-name>"

  local name="$1"
  local repo_dir="${REPOS_DIR}/${name}"
  [[ -d "$repo_dir" ]] || die "repo '${name}' not found"

  # Remove all symlinks pointing into this repo across home and common project locations
  while IFS= read -r skill; do
    [[ -n "$skill" ]] || continue
    # Find symlinks everywhere that point into this repo
    while IFS= read -r link; do
      local target
      target="$(readlink "$link")"
      if [[ "$target" == "${repo_dir}/"* ]]; then
        rm "$link"
        echo "unlinked: ${link}"
      fi
    done < <(find "$HOME" -type l -lname "${repo_dir}/*" 2>/dev/null || true)
  done < <(list_skills_in_repo "$repo_dir")

  rm -rf "$repo_dir"
  echo "uninstalled: ${name}"
}

# ── update ───────────────────────────────────────────────────────────────────

cmd_update() {
  local found=false
  for repo_dir in "${REPOS_DIR}"/*/; do
    [[ -d "$repo_dir" ]] || continue
    found=true
    local name
    name="$(basename "$repo_dir")"

    if [[ -d "${repo_dir}/.git" ]]; then
      echo "updating ${name}..."
      git -C "$repo_dir" pull --ff-only 2>&1 | sed 's/^/  /'
    else
      echo "skipping ${name} (not a git repo)"
    fi
  done

  $found || echo "no repos installed"
}

# ── list ─────────────────────────────────────────────────────────────────────

cmd_list() {
  local found=false

  for repo_dir in "${REPOS_DIR}"/*/; do
    [[ -d "$repo_dir" ]] || continue
    found=true
    local repo_name
    repo_name="$(basename "$repo_dir")"

    echo -e "\033[1;34m${repo_name}\033[0m"

    while IFS= read -r skill; do
      [[ -n "$skill" ]] || continue

      # Check for links in home dir
      local home_links
      home_links="$(find_links_for_skill "$skill" "$HOME")"

      if [[ -n "$home_links" ]]; then
        echo -e "  \033[1;32m${skill}\033[0m (global)"
        while IFS= read -r link; do
          echo -e "    \033[0;32m-> ${link}\033[0m"
        done <<< "$home_links"
      else
        echo -e "  \033[0;37m${skill}\033[0m (not linked)"
      fi
    done < <(list_skills_in_repo "$repo_dir")
    echo
  done

  $found || echo "no repos installed"
}

# ── main ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
skillctl - manage agent skills across harnesses

usage:
  skillctl install <url|local-path>       clone/copy a skill repo
  skillctl link [skill] [--global] [--project <path>]
  skillctl unlink [skill] [--global] [--project <path>]
  skillctl uninstall <repo-name>          remove repo and all symlinks
  skillctl update                         git pull all repos
  skillctl list                           show repos, skills, and link status
EOF
}

case "${1:-}" in
  install)   shift; cmd_install "$@" ;;
  link)      shift; cmd_link "$@" ;;
  unlink)    shift; cmd_unlink "$@" ;;
  uninstall) shift; cmd_uninstall "$@" ;;
  update)    shift; cmd_update "$@" ;;
  list)      shift; cmd_list "$@" ;;
  -h|--help|help) usage ;;
  "") usage; exit 1 ;;
  *) die "unknown command: $1" ;;
esac
