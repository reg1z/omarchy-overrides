#!/bin/bash

USER_HOME=$(eval echo "~${SUDO_USER:-$USER}")
USER_DOTS="$USER_HOME/repos/omarchy-overrides"
SCRIPTS="$USER_DOTS/scripts"
USER_BINS="$USER_DOTS/scripts/bin"
LOCAL_BIN="$USER_HOME/.local/bin"
GHOSTTY_CFG="$USER_HOME/.config/ghostty"

SPINNER="pulse"
SPINNER_EMPHASIS="moon"



config_terminal() {
  # Backup ghostty sys defaults
  if [[ ! -f "$GHOSTTY_CFG/config.bak" ]]; then
    echo "Backing up ghostty config."
    cp "$GHOSTTY_CFG/config" "$GHOSTTY_CFG/config.bak"
    echo "Ghostty config backed up:"
    echo "$GHOSTTY_CFG/config.bak"
  fi

  rm "$GHOSTTY_CFG/config"
  ln -s "$USER_DOTS/ghostty/config" "$GHOSTTY_CFG/config"
}

setup_bash() {
  # init .bashrc just in case
  gum spin \
    --spinner "$SPINNER" \
    --title "Setting up bash..." \
    -- bash -c "sleep 2; exit"

  stamp='# ----- appended ----- omarchy-overrides -----'

  if [[ -f "$USER_HOME/.bashrc" ]]; then
    stamped=$(grep -E "$stamp" $USER_HOME/.bashrc)
    if [[ -z "$stamped" ]]; then
      echo "No append stamp detected. Appending content..."
      cat "$USER_DOTS/shell/bash/appendrc" >> "$USER_HOME/.bashrc"
    fi
  else
    echo "No .bashrc detected."
  fi

  echo "Shell set."
}

setup_zsh() {
  # install omarchy-zsh
  echo "Installing omarchy-zsh..."
  yay -S --noconfirm --needed omarchy-zsh

  omarchy-setup-zsh;

  # init .zshrc just in case
  gum spin \
    --spinner "$SPINNER" \
    --title "Setting up zsh..." -- zsh -c "sleep 2; exit"

  if [[ -f "$USER_HOME/.zshrc" ]]; then
    cat "$USER_DOTS/shell/zsh/appendrc" >> "$USER_HOME/.zshrc"
  else
    echo "No .zshrc detected."
  fi

  echo "Shell set."
}

setup_fish() {
  # install omarchy-fish
  echo "Installing omarchy-fish..."
  yay -S --noconfirm --needed omarchy-fish

  omarchy-setup-fish;

  # init fishies just in case
  gum spin \
    --spinner "$SPINNER" \
    --title "Setting up fish..." \
    -- fish -c "sleep 2; exit"

  if [[ -f "$USER_HOME/.config/fish/config.fish" ]]; then
    cat "$USER_DOTS/shell/fish/append.fish" >> "$USER_HOME/.config/fish/config.fish"
  else
    echo "No config.fish detected."
  fi

  echo "Shell set."
}

# Create a backup
create_backup() {
    local target_file="$1"

    if [[ -z "$target_file" ]]; then
        echo "Usage: create_backup <file>" >&2
        return 1
    fi

    if [[ ! -f "$target_file" ]]; then
        echo "Error: File not found: $target_file" >&2
        return 1
    fi
    
    # Generate timestamp in format YYYYMMDD-HHMMSS
    local timestamp=$(date +%Y%m%d-%H%M%S)
    local backup_file="${target_file}.backup-${timestamp}"
    
    # Copy file to backup
    cp "$target_file" "$backup_file"
    
    if [[ $? -eq 0 ]]; then
        echo "Backup created: $backup_file"
        return 0
    else
        echo "Error: Failed to create backup" >&2
        return 1
    fi
}

# For finding .bashrc backups
find_latest_backup() {
    local target_file="$1"
    
    if [[ -z "$target_file" ]]; then
        echo "Usage: find_backups <file>" >&2
        return 1
    fi
    
    local filename=$(basename "$target_file")
    local directory=$(dirname "$target_file")
    
    # Handle relative paths
    if [[ "$directory" == "." ]]; then
        directory="."
    fi
    
    # Find latest BASH backup
    
    files=($( \
      find "$directory" \
      -maxdepth 1 \
      -type f \
      -name "${filename}.backup-*" \
      2>/dev/null | sort -r \
    ))
    
    for file in "${files[@]}"; do
      local term=$(grep -iE "fish|zsh" "$file")
      if [[ -z "$term" ]]; then
        echo "$file"
      else
        continue
      fi
    done
    
}


shell=$(gum choose --limit 1 --header "What's your preferred shell?" \
  "bash" \
  "zsh" \
  "fish")

case $shell in
  "bash")
    echo -e "Setting up bash..."
    backup=$(find_latest_backup "$USER_HOME/.bashrc")
    echo -e "\nbash .bashrc backup found:\n$backup"
    if [[ ! -z "$backup" ]]; then
      echo -e "\nThe program will now restore the backup\nand backup your existing configuration."
      if gum confirm "Continue?"; then
        create_backup "$USER_HOME/.bashrc"
        rm "$USER_HOME/.bashrc"
        mv "$backup" "$USER_HOME/.bashrc"
      else
        $USER_DOTS/scripts/bin/omarchy-choose-shell
        exit 0
      fi
    fi
    setup_bash
    ;;
  "zsh")
    echo -e "Setting up zsh..."
    setup_zsh
    ;;
  "fish")
    echo -e "Setting up fish"
    setup_fish
    ;;
  *)
    echo -e "No shell selected."
    ;;
esac

config_terminal

#find_latest_backup "$USER_HOME/.bashrc"

exit 0
