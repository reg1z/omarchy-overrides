# environment variables

export PATH="$HOME/.local/bin:$HOME/.cache/.bun/bin:$PATH:$HOME/.cargo/bin:"
export SSH_AUTH_SOCK=$HOME/.bitwarden-ssh-agent.sock

export DOTS=$HOME/.local/share/omarchy-overrides
export DOTS_BIN="$HOME/.local/share/omarchy-overrides/scripts/bin"
export USER_BIN=$HOME/.local/bin

# Disabling Telemetry
DISABLE_TELEMETRY=1                              # generic best-effort
DO_NOT_TRACK=1                                   # console do-not-track standard
DOTNET_CLI_TELEMETRY_OPTOUT=1                    # .NET CLI
DOTNET_UPGRADEASSISTANT_TELEMETRY_OPTOUT=1       # .NET Upgrade Assistant
POWERSHELL_TELEMETRY_OPTOUT=1                    # PowerShell
AZURE_CORE_COLLECT_TELEMETRY=0                   # Azure CLI
HOMEBREW_NO_ANALYTICS=1                          # Homebrew
CHECKPOINT_DISABLE=1                             # HashiCorp tools (Terraform, Vault, Packer, Vagrant, Nomad, cdktf) + Prisma
NPM_CONFIG_FUND=false                            # npm funding messages
NPM_CONFIG_AUDIT=false                           # npm auto-audit on install
NPM_CONFIG_UPDATE_NOTIFIER=false                 # npm update nag
PIP_DISABLE_PIP_VERSION_CHECK=1                  # pip
GH_NO_TELEMETRY=1                                # GitHub CLI
SAM_CLI_TELEMETRY=0                              # AWS SAM CLI
WRANGLER_SEND_METRICS=false                      # Cloudflare Wrangler
SLS_TELEMETRY_DISABLED=1                         # Serverless Framework
NEXT_TELEMETRY_DISABLED=1                        # Next.js
NUXT_TELEMETRY_DISABLED=1                        # Nuxt
ASTRO_TELEMETRY_DISABLED=1                       # Astro
GATSBY_TELEMETRY_DISABLED=1                      # Gatsby
TURBO_TELEMETRY_DISABLED=1                       # Turborepo
STORYBOOK_DISABLE_TELEMETRY=1                    # Storybook
STORYBOOK_ENABLE_CRASH_REPORTS=0                 # Storybook crash reports (separate toggle)
REDWOOD_TELEMETRY_DISABLED=1                     # RedwoodJS
EXPO_NO_TELEMETRY=1                              # Expo / React Native
NG_CLI_ANALYTICS=false                           # Angular CLI
PULUMI_SKIP_UPDATE_CHECK=true                    # Pulumi version checks
PULUMI_DISABLE_AUTOMATIC_PLUGIN_ACQUISITION=true # Pulumi plugin fetch
ALGOLIA_CLI_TELEMETRY=0                          # Algolia CLI
GEMINI_TELEMETRY_ENABLED=false                   # Google Gemini CLI (inverted: false = disabled)
